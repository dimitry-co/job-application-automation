#!/usr/bin/env bash
set -euo pipefail

msg_file="${1:-}"
if [[ -z "$msg_file" || ! -f "$msg_file" ]]; then
  echo "[commit-msg] Missing commit message file."
  exit 1
fi

msg="$(head -n1 "$msg_file" | tr -d '\r')"

# Allow merge/revert commits generated by git.
if [[ "$msg" =~ ^Merge\  || "$msg" =~ ^Revert\  ]]; then
  exit 0
fi

if [[ ! "$msg" =~ ^(feat|fix|chore|docs|refactor|test|build|ci|perf)(\([a-z0-9._/-]+\))?:\ .+ ]]; then
  echo "[commit-msg] Use: <type>(optional-scope): <summary>"
  echo "[commit-msg] Example: feat(api): add jobs sync endpoint"
  exit 1
fi
